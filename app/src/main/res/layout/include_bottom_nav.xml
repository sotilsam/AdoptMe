<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/bottom_bar_height"
    android:paddingStart="26dp"
    android:paddingEnd="26dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/navChat"
            android:layout_width="@dimen/nav_icon_size"
            android:layout_height="@dimen/nav_icon_size"
            android:background="@android:color/transparent"
            android:contentDescription="Contact"
            app:srcCompat="@drawable/mail"
            android:padding="@dimen/nav_icon_padding"/>

        <Space android:layout_width="38dp" android:layout_height="1dp"/>

        <ImageButton
            android:id="@+id/navFavorites"
            android:layout_width="@dimen/nav_icon_size"
            android:layout_height="@dimen/nav_icon_size"
            android:background="@android:color/transparent"
            android:contentDescription="Favorites"
            app:srcCompat="@drawable/favorite"
            android:padding="@dimen/nav_icon_padding"/>

        <Space android:layout_width="38dp" android:layout_height="1dp"/>

        <ImageButton
            android:id="@+id/navHome"
            android:layout_width="@dimen/nav_icon_size"
            android:layout_height="@dimen/nav_icon_size"
            android:background="@android:color/transparent"
            android:contentDescription="Home"
            app:srcCompat="@drawable/ic_paw"
            android:padding="@dimen/nav_icon_padding"/>

        <Space android:layout_width="38dp" android:layout_height="1dp"/>

        <ImageButton
            android:id="@+id/navProfile"
            android:layout_width="@dimen/nav_icon_size"
            android:layout_height="@dimen/nav_icon_size"
            android:background="@android:color/transparent"
            android:contentDescription="Profile"
            app:srcCompat="@drawable/profile"
            android:padding="@dimen/nav_icon_padding"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
