<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg">

    <TextView
        android:id="@+id/tvPreferencesTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Preferences"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_yellow"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="39dp"
        app:layout_constraintTop_toBottomOf="@id/tvPreferencesTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pet Type"
            android:textSize="20sp"
            android:textColor="@color/text_yellow"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <CheckBox
                android:id="@+id/cbDog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dog"
                android:textSize="18sp"
                android:textColor="@color/text_white"
                android:buttonTint="@color/text_yellow" />

            <CheckBox
                android:id="@+id/cbCat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cat"
                android:textSize="18sp"
                android:textColor="@color/text_white"
                android:layout_marginStart="20dp"
                android:buttonTint="@color/text_yellow" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pet Size"
            android:textSize="20sp"
            android:textColor="@color/text_yellow"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <CheckBox
                android:id="@+id/cbSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Small"
                android:textSize="18sp"
                android:textColor="@color/text_white"
                android:buttonTint="@color/text_yellow" />

            <CheckBox
                android:id="@+id/cbMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:textSize="18sp"
                android:textColor="@color/text_white"
                android:layout_marginStart="20dp"
                android:buttonTint="@color/text_yellow" />

            <CheckBox
                android:id="@+id/cbLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Large"
                android:textSize="18sp"
                android:textColor="@color/text_white"
                android:layout_marginStart="20dp"
                android:buttonTint="@color/text_yellow" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Search_Radius"
            android:textSize="20sp"
            android:textColor="@color/text_yellow" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvRadiusValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="@string/km"
                android:textColor="@color/text_white" />
        </RelativeLayout>

        <SeekBar
            android:id="@+id/sbRadius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="30"
            android:progressTint="@color/text_yellow"
            android:thumbTint="@color/text_yellow" />

        <Button
            android:id="@+id/btnSavePreferences"
            style="@style/RoundedGrayButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Preferences"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_round_button"
            app:backgroundTint="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
